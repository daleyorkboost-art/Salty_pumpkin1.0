    "build:frontend": "vite build",
    "lint": "eslint \"src/**/*.{js,jsx}\" index.js server.js app.js lib/store.js lib/config.js",
    "test": "npm run lint && node --test && node --check index.js && node --check server.js && node --check app.js && node --check lib/store.js && node --check lib/config.js && node --check lib/delhivery.js"
  },
