# ---- Bootstrap only ----
NODE_ENV=production
PORT=5000

# Optional. Defaults to ./data. Use an absolute path when persistent data should
# live outside the deployed app directory.
DATA_DIR=

# Leave blank when Express serves the website and API on the same domain.
# If the frontend is hosted separately, set this before building, for example:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Required. A long random string used to sign login tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Required before saving any secret from the admin panel.
# Use exactly 32 bytes, or a 64-character hex string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=

# Required for first admin login. Admin role is never inferred from email/phone patterns.
ADMIN_EMAILS=owner@yourdomain.com
ADMIN_PHONES=

# Firebase client project is centralized in src/firebase-config.js.
# Firebase Admin verifies ID tokens using this project ID; no service-account key is bundled.
GOOGLE_CLOUD_PROJECT=salty-pumpkin
# Required for backend-created Firebase sessions after secure Phone OTP verification.
# Paste the complete service-account JSON as one environment-variable value in Hostinger.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional. If set, store data uses MongoDB in later phases; JSON file storage is used now when unset.
MONGODB_URI=

# Required for live Razorpay checkout. Set these in Hostinger environment variables.
# Never put RAZORPAY_KEY_SECRET in frontend code or commit a populated .env file.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Delhivery credentials and fulfillment settings. The pickup location must
# exactly match a warehouse name registered in the Delhivery account.
DELHIVERY_API_TOKEN=
DELHIVERY_API_BASE_URL=https://track.delhivery.com
DELHIVERY_PICKUP_LOCATION=
DELHIVERY_ORIGIN_PINCODE=
DELHIVERY_DEFAULT_WEIGHT_GRAMS=500
DELHIVERY_SHIPPING_MODE=Surface
DELHIVERY_SYNC_INTERVAL_MINUTES=30
DELHIVERY_WEBHOOK_SECRET=

# Everything else can be configured in the admin Settings panel:
# SMTP, OTP, Cloudinary, shipping/tax, analytics, CORS, store info, and delivery.

# Optional direct integration env vars copied from the dynamic admin integration package.
META_PIXEL_ID=1142652131080335
META_CONVERSIONS_ACCESS_TOKEN=
GA4_MEASUREMENT_ID=G-1KYL0HZGWC
GTM_ID=GTM-NH8QVC28
TWOFACTOR_API_KEY=
TWOFACTOR_TEMPLATE_ID=Salty Pumpkin OTP Verification
# Optional for provider-compatible testing. Leave blank in production.
TWOFACTOR_API_BASE_URL=
CORS_ORIGIN=
